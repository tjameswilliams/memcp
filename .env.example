# Server Port
PORT=3000

# Database Path (inside the container)
MEMCP_DB_PATH=/app/data/memcp.db

# Embedding Provider ('local' or 'openai')
MEMCP_EMBEDDING_PROVIDER=local

# OpenAI Configuration (only needed if PROVIDER='openai')
# MEMCP_EMBEDDING_KEY=sk-your-api-key-here
# MEMCP_EMBEDDING_URL=https://api.openai.com/v1
# MEMCP_EMBEDDING_MODEL=text-embedding-3-small

# API Key for server authentication (leave empty for open access)
# Auto-generated during install. Set a custom key with:
#   npm run cli generate-api-key
# MEMCP_API_KEY=
